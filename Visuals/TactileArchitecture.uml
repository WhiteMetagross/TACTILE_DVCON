@startuml TACTILE_Stage2A_Architecture

skinparam backgroundColor #1a1a2e
skinparam defaultFontName Monospaced
skinparam defaultFontSize 11
skinparam defaultFontColor #dde1f0
skinparam ArrowColor #6ea8fe
skinparam ArrowFontColor #adb5bd
skinparam shadowing false

skinparam rectangle {
    BackgroundColor #252545
    BorderColor #6ea8fe
    FontColor #dde1f0
    RoundCorner 6
}

skinparam package {
    BackgroundColor #0d0d1f
    BorderColor #3a3a6a
    FontColor #8888cc
    FontStyle bold
}

skinparam database {
    BackgroundColor #1a2e1a
    BorderColor #66cc88
    FontColor #dde1f0
}

skinparam actor {
    BackgroundColor #252545
    BorderColor #6ea8fe
    FontColor #dde1f0
}

skinparam note {
    BackgroundColor #1c1c30
    BorderColor #44445a
    FontColor #aaaacc
}

title TACTILE Stage 2A -- End-to-End Inference Pipeline

actor "User" as User

package "Inputs" {
    rectangle "Image\n(JPEG or PNG)" as Image
    rectangle "Task ID\n(integer 0 to 13)" as TaskId
}

package "Preprocessing" {
    rectangle "load_image\nResize to working resolution\nConvert to RGB float tensor" as Preproc
    rectangle "preprocess_for_sam\nScale to 160x160\nPrepare SAM input tensor" as PrepSam
    rectangle "preprocess_for_yolo\nScale to 160x160\nPrepare YOLO input tensor" as PrepYolo
}

package "Stage 1 -- Backbone Detection" {
    rectangle "YOLOv5n Detector\n[YoloV5nWrapper.py]\nAnchor-based detector\nINT8-ready backbone\n160x160 fixed input size\nOutputs N raw bounding box proposals\nwith class and confidence scores" as YOLO
}

package "Stage 2 -- Spatial Attention Gating" {
    rectangle "SAM-IP\n[SamIp.py]\nThree-layer lightweight CNN\nConv3x3 stride 2 (4 ch)\nDWConv3x3 stride 2 (4 ch)\nPW Conv1x1 (1 ch)\nBilinear upsample to 40x40\n677 total parameters\nOutputs per-task binary spatial mask" as SAMIP
    rectangle "Soft Gating\n[SoftGate.py]\nFor each proposal: check if\ncenter falls in a mask-zero cell\nMultiply confidence by alpha 0.25\nAll proposals are preserved" as SoftGate
}

package "Stage 3 -- RoI Feature Extraction" {
    rectangle "RoI Feature Extraction\n[RoiExtract.py]\nCrop-based spatial pooling\nExtracts 128-dimensional\nfeature vector per proposal" as RoI
}

package "Stage 4 -- Task Scoring" {
    rectangle "Task Embedding Table\n[TaskEmb.py]\n14 learned embeddings\nEach embedding is 128-D\nLookup is performed by task_id" as TaskEmb
    rectangle "Task Score\n[TaskScore.py]\nComputes dot product of\nproposal feature (128-D)\nand task embedding (128-D)\nReturns one score per proposal" as TaskScore
}

package "Stage 5 -- Task-Fused NMS" {
    rectangle "Fused NMS\n[FusedNms.py]\nfused = conf x task_score x prior[class][task]\nDivision-free IoU suppression\nSuppresses task-irrelevant boxes\nOutputs top-K ranked detections" as FusedNMS
}

package "Pretrained Weights" {
    database "yolov5nu.pt\nYOLOv5n backbone weights" as YoloWeights
    database "SamIp.pth\nTrained SAM-IP gate weights" as SamWeights
    database "TaskEmbeddings.npy\n14 x 128 dimensions" as EmbWeights
    database "ClassTaskPrior.npy\n80 x 14 prior table\nfraction of preferred class\nper task from COCO-Tasks data" as PriorTable
    database "SamThresholds\nPer-task binarization\nfloat thresholds" as SamThresh
}

package "Output" {
    rectangle "Top-1 Detection Result\nbbox: [x1, y1, x2, y2]\nclass: detected class name\nconfidence: fused score\ntask: task name string" as Output
}

User --> Image
User --> TaskId
Image --> Preproc
TaskId --> Preproc
Preproc --> PrepSam
Preproc --> PrepYolo
PrepYolo --> YOLO
PrepSam --> SAMIP
YOLO --> SoftGate
SAMIP --> SoftGate
SoftGate --> RoI
PrepYolo --> RoI
RoI --> TaskScore
TaskId --> TaskEmb
TaskEmb --> TaskScore
TaskScore --> FusedNMS
SoftGate --> FusedNMS
PriorTable --> FusedNMS
FusedNMS --> Output

YoloWeights ..> YOLO
SamWeights ..> SAMIP
EmbWeights ..> TaskEmb
SamThresh ..> SAMIP

note right of SoftGate
  Novel Contribution 1: SAM-IP Soft Gating.
  Proposals are never discarded outright.
  Proposals whose center falls outside
  the spatial mask are attenuated by 0.25.
  This ensures no object is missed due
  to an imperfect spatial mask.
end note

note right of FusedNMS
  Novel Contribution 2: Task-Fused NMS.
  Fused score = conf x task_score x prior.
  Task-aware ranking surfaces wine glass
  over a high-confidence kite for the
  task: Serve Wine.
  Uses division-free IoU computation
  for hardware synthesis compatibility.
end note

note bottom of YOLO
  YOLOv5n is selected over YOLOv8, YOLOv11,
  and YOLO26. Newer NMS-Free architectures
  suppress proposals inside the network.
  The Fused NMS stage requires raw overlapping
  proposals to inject task-aware scores
  before suppression occurs.
end note

@enduml