@startuml TACTILE_Stage2A_Architecture

skinparam backgroundColor #1e1e2e
skinparam defaultFontName "Courier New"
skinparam defaultFontSize 11
skinparam defaultFontColor #cdd6f4
skinparam ArrowColor #89b4fa
skinparam ArrowFontColor #bac2de

skinparam actor {
    BackgroundColor #313244
    BorderColor #89b4fa
    FontColor #cdd6f4
}

skinparam component {
    BackgroundColor #313244
    BorderColor #89b4fa
    FontColor #cdd6f4
}

skinparam package {
    BackgroundColor #181825
    BorderColor #585b70
    FontColor #89b4fa
    FontStyle bold
}

skinparam database {
    BackgroundColor #313244
    BorderColor #a6e3a1
    FontColor #cdd6f4
}

skinparam note {
    BackgroundColor #2a2a3e
    BorderColor #585b70
    FontColor #bac2de
}

title TACTILE Stage 2A -- End-to-End Inference Pipeline

actor "User" as User

package "Inputs" {
    component "Image\n(JPEG / PNG)" as Image
    component "Task ID\n(integer 0..13)" as TaskId
}

package "Preprocessing" {
    component "load_image()\nResize and RGB normalize" as Preproc
    component "preprocess_for_sam()\n160x160 float tensor" as PrepSam
    component "preprocess_for_yolo()\n160x160 float tensor" as PrepYolo
}

package "Stage 1: Backbone Detection" {
    component "YOLOv5n Detector\n(YoloV5nWrapper.py)\nAnchor-based, INT8-ready\n160x160 input -- 75 raw proposals" as YOLO
}

package "Stage 2: Spatial Attention" {
    component "SAM-IP\n(SamIp.py)\nConv3x3 -> DWConv3x3 -> PW1x1\nOutputs 40x40 binary mask\n677 parameters total" as SAMIP
    component "Soft Gating\n(SoftGate.py)\nMultiplies off-mask proposal\nconfidence by alpha=0.25" as SoftGate
}

package "Stage 3: Feature Extraction" {
    component "RoI Feature Extraction\n(RoiExtract.py)\nCrop-based spatial pooling\n128-D vector per proposal" as RoI
}

package "Stage 4: Task Scoring" {
    component "Task Embedding Table\n(TaskEmb.py)\n14 x 128-D learned embeddings\nLookup by task_id" as TaskEmb
    component "Task Score\n(TaskScore.py)\nDot product:\nproposal_feat . task_emb" as TaskScore
}

package "Stage 5: Fused NMS" {
    component "Fused NMS\n(FusedNms.py)\nfused = conf x task_score x prior\nDivision-free IoU suppression\nOutputs top-K results" as FusedNMS
}

database "Pretrained Weights" {
    component "yolov5nu.pt" as YoloWeights
    component "SamIp.pth" as SamWeights
    component "TaskEmbeddings.npy\n14 x 128" as EmbWeights
    component "ClassTaskPrior.npy\n80 x 14" as PriorTable
    component "SamThresholds\nper-task float" as SamThresh
}

package "Output" {
    component "Top-1 Detection\n{bbox, class, confidence, task}" as Output
}

' Main data flow.
User --> Image
User --> TaskId
Image --> Preproc
TaskId --> Preproc
Preproc --> PrepSam
Preproc --> PrepYolo
PrepYolo --> YOLO
PrepSam --> SAMIP
YOLO --> SoftGate
SAMIP --> SoftGate
SoftGate --> RoI
PrepYolo --> RoI
RoI --> TaskScore
TaskId --> TaskEmb
TaskEmb --> TaskScore
TaskScore --> FusedNMS
SoftGate --> FusedNMS
PriorTable --> FusedNMS
FusedNMS --> Output

' Weight loading (dashed).
YoloWeights ..> YOLO
SamWeights ..> SAMIP
EmbWeights ..> TaskEmb
SamThresh ..> SAMIP

note right of SoftGate
  Novel Contribution 1.
  All proposals are preserved.
  Off-mask ones are attenuated only.
end note

note right of FusedNMS
  Novel Contribution 2.
  Three-way score fusion before NMS.
  Surfaces wine glass over kite
  for task: Serve Wine.
end note

note bottom of YOLO
  YOLOv5n is chosen over v8, v11, v26.
  Newer NMS-Free models suppress proposals
  internally, breaking the Fused NMS stage.
end note

@enduml
