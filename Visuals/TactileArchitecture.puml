title <color:#1565c0><b>TACTILE</b></color> <color:#546e7a>Stage 2A:</color> <color:#1a237e><b>Complete Inference Pipeline</b></color>

actor "User" as User

package "Inputs" <<inputs>> {
    rectangle "Image\n(JPEG or PNG)" <<inputs>> as Image
    rectangle "Task ID\n(integer 0 to 13)" <<inputs>> as TaskId
}

package "Preprocessing" <<preproc>> {
    rectangle "load_image\nResize to working resolution\nConvert to RGB float tensor" <<preproc>> as Preproc
    rectangle "preprocess_for_sam\nScale to 160x160\nPrepare SAM input tensor" <<preproc>> as PrepSam
    rectangle "preprocess_for_yolo\nScale to 160x160\nPrepare YOLO input tensor" <<preproc>> as PrepYolo
}

package "Stage 1: Backbone Detection" <<stage1>> {
    rectangle "YOLOv5n Detector\n[YoloV5nWrapper.py]\nAnchor-based detector\nINT8-ready backbone\n160x160 fixed input size\nOutputs N raw bounding box proposals\nwith class and confidence scores" <<stage1>> as YOLO
}

package "Stage 2: Spatial Attention Gating" <<stage2>> {
    rectangle "SAM-IP\n[SamIp.py]\nThree-layer lightweight CNN\nConv3x3 stride 2 (4 ch)\nDWConv3x3 stride 2 (4 ch)\nPW Conv1x1 (1 ch)\nBilinear upsample to 40x40\n677 total parameters\nOutputs per-task binary spatial mask" <<stage2>> as SAMIP
    rectangle "Soft Gating\n[SoftGate.py]\nFor each proposal: check if\ncenter falls in a mask-zero cell\nMultiply confidence by alpha 0.25\nAll proposals are preserved" <<stage2>> as SoftGate
}

package "Stage 3: RoI Feature Extraction" <<stage3>> {
    rectangle "RoI Feature Extraction\n[RoiExtract.py]\nCrop-based spatial pooling\nExtracts 128-dimensional\nfeature vector per proposal" <<stage3>> as RoI
}

package "Stage 4: Task Scoring" <<stage4>> {
    rectangle "Task Embedding Table\n[TaskEmb.py]\n14 learned embeddings\nEach embedding is 128-D\nLookup is performed by task_id" <<stage4>> as TaskEmb
    rectangle "Task Score\n[TaskScore.py]\nComputes dot product of\nproposal feature (128-D)\nand task embedding (128-D)\nReturns one score per proposal" <<stage4>> as TaskScore
}

package "Stage 5: Task-Fused NMS" <<stage5>> {
    rectangle "Fused NMS\n[FusedNms.py]\nfused = conf x task_score x prior[class][task]\nDivision-free IoU suppression\nSuppresses task-irrelevant boxes\nOutputs top-K ranked detections" <<stage5>> as FusedNMS
}

package "Pretrained Weights" <<weights>> {
    database "yolov5nu.pt\nYOLOv5n backbone weights" as YoloWeights
    database "SamIp.pth\nTrained SAM-IP gate weights" as SamWeights
    database "TaskEmbeddings.npy\n14 x 128 dimensions" as EmbWeights
    database "ClassTaskPrior.npy\n80 x 14 prior table\nfraction of preferred class\nper task from COCO-Tasks data" as PriorTable
    database "SamThresholds\nPer-task binarization\nfloat thresholds" as SamThresh
}

package "Output" <<output>> {
    rectangle "Top-1 Detection Result\nbbox: [x1, y1, x2, y2]\nclass: detected class name\nconfidence: fused score\ntask: task name string" <<output>> as FinalOutput
}

User --> Image
User --> TaskId
Image --> Preproc
TaskId --> Preproc
Preproc --> PrepSam
Preproc --> PrepYolo
PrepYolo --> YOLO
PrepSam --> SAMIP
YOLO --> SoftGate
SAMIP --> SoftGate
SoftGate --> RoI
PrepYolo --> RoI
RoI --> TaskScore
TaskId --> TaskEmb
TaskEmb --> TaskScore
TaskScore --> FusedNMS
SoftGate --> FusedNMS
FusedNMS --> FinalOutput

YoloWeights ..> YOLO
SamWeights ..> SAMIP
EmbWeights ..> TaskEmb
SamThresh ..> SAMIP
PriorTable ..> FusedNMS

note right of SoftGate
  <b><color:#004d40>Novel Contribution 1: SAM-IP Soft Gating</color></b>
  Proposals are never discarded outright.
  Proposals whose center falls outside
  the spatial mask are attenuated by 0.25.
  This ensures no object is missed due
  to an imperfect spatial mask.
end note

note right of FusedNMS
  <b><color:#b71c1c>Novel Contribution 2: Task-Fused NMS</color></b>
  Fused score = conf x task_score x prior.
  Task-aware ranking surfaces wine glass
  over a high-confidence kite for the
  task: Serve Wine.
  Uses division-free IoU computation
  for hardware synthesis compatibility.
end note

note bottom of YOLO
  YOLOv5n is selected over YOLOv8, YOLOv11,
  and YOLO26. Newer NMS-Free architectures
  suppress proposals inside the network.
  The Fused NMS stage requires raw overlapping
  proposals to inject task-aware scores
  before suppression occurs.
end note

@enduml